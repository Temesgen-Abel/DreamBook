<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Notifications</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { font-family: Arial, sans-serif; }

    .notif-container {
      width: 80%;
      margin: 20px auto;
    }

    .notif-card {
      background: white;
      border-radius: 10px;
      padding: 15px;
      margin-bottom: 12px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.15);
      border-left: 5px solid #3498db;
      transition: background 0.2s ease;
    }

    .notif-card.unread {
      background: #eef6ff;
      border-left-color: #e74c3c;
    }

    .notif-card small {
      color: #666;
    }

    .mark-read-btn {
      margin: 20px 0;
      padding: 10px 20px;
      background: #27ae60;
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
    }

    .mark-read-btn:hover {
      background: #219150;
    }
  </style>
</head>
<body>

<%- include("includes/header") %>

<div class="notif-container">
  <h2>Notifications</h2>

  <form action="/notifications/mark-all-read" method="POST">
    <button class="mark-read-btn">Mark all as read</button>
  </form>

  <% if (notifications.length === 0) { %>
    <p>No notifications yet.</p>
  <% } %>

  <% notifications.forEach(n => { %>
    <div class="notif-card <%= n.is_read ? '' : 'unread' %>">
      <strong><%= n.sendername %></strong> sent you a message:
      <p><%= n.message.substring(0, 80) %>...</p>
      <small><%= n.createdAt %></small>
    </div>
  <% }) %>
</div>

<%- include("includes/footer") %>

</body>
</html>
