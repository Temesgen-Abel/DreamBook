<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
  <%- include("includes/head") %>

  <title><%= title || "DreamBook Community Dashboard" %></title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= description || 'Browse dreams shared by the DreamBook community. Explore, like, and comment on dreams from users around the world.' %>">
  <link rel="canonical" href="https://dreambook.com.et/dashboard">

  <!-- Social / Open Graph -->
  <meta property="og:title" content="<%= title || 'DreamBook Community Dashboard' %>">
  <meta property="og:description" content="<%= description || 'Browse dreams shared by the DreamBook community. Explore, like, and comment on dreams from users around the world.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://dreambook.com.et/dashboard">
  <meta property="og:image" content="https://dreambook.com.et/img/og-dashboard.png">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title || 'DreamBook Community Dashboard' %>">
  <meta name="twitter:description" content="<%= description || 'Browse dreams shared by the DreamBook community. Explore, like, and comment on dreams from users around the world.' %>">
  <meta name="twitter:image" content="https://dreambook.com.et/img/og-dashboard.png">

  <!-- Prevent indexing for private content -->
  <meta name="robots" content="noindex, follow">
</head>

<body>
  <%- include("includes/header") %>

  <main class="wrapper page-wrapper dashboard-page">
<form action="/create-post" method="post"> 
   <h1>Community Dream Posts</h1>
  <input type="text" name="body" placeholder="Share Your Dream">
  <button class="btn" type="submit">Post</button>
</form>

<aside class="online-users-panel" style="margin: 20px 0;padding: 12px;border: 1px solid #ddd;border-radius: 8px;background: #fff;">
  <button id="online-users-toggle" onclick="toggleOnlineUsers()" style="background:none;border:none;cursor:pointer;font-size:inherit;">Online users (<%= onlineUsers?.length || 0 %>)</button>
  <div id="online-users-content" style="display:none;">
  <ul id="online-users-list" style="list-style:none;padding:0;margin:0;">
    <% if (onlineUsers && onlineUsers.length > 0) { %>
      <% onlineUsers.forEach(u => { %>
        <li style="margin:4px 0;"><a href="/chat/<%= u.id %>" style="text-decoration:none;">✅ <%= u.username %></a></li>
      <% }) %>
    <% } %>
  </ul>
  <% if (!onlineUsers || onlineUsers.length === 0) { %>
    <p id="online-users-empty" style="margin:0.4rem 0 0;">No users online right now.</p>
  <% } %>
  </div>
</aside>

    <div class="posts-list">
      <% if (posts.length) { %>
        <% posts.forEach(post => { %>
          <article class="post-card <%= post.is_live_share ? 'live-share-post' : '' %>">
            <h2>
              <a href="/post/<%= post.id %>">
                <%= post.username %>'s Dream
                <% if (post.is_live_share) { %>
                  <span class="live-indicator">🎥 LIVE</span>
                <% } %>
              </a>
            </h2>
            <p><%- post.body %></p>

            <div class="reactions">
              👍 <%= countReactions.get(post.id)?.likes || 0 %> • 👎 <%= countReactions.get(post.id)?.dislikes || 0 %>
              
            </div>

            <small>
              <%
              const date = post.createdDate ? new Date(post.createdDate) : null;
              const isValidDate = date && !isNaN(date.getTime());
            %>

            <time createdDate="<%= isValidDate ? date.toISOString() : '' %>">
              <%= isValidDate ? date.toLocaleDateString() : 'Unknown date' %>

            </time>
            </small>

            <a href="/post/<%= post.id %>" class="btn">Read Interpretation</a>

            <% if (user && Number(post.authorid) === Number(user.id)) { %>
              <form action="/delete-post/<%= post.id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn danger">Delete</button>
              </form>
            <% } %>
          </article>
        <% }) %>
      <% } else { %>
        <p>No dreams have been shared yet. <a href="/create-post">Be the first to share your dream!</a></p>
      <% } %>
    </div>

    <nav class="pagination">
      <% if (currentPage > 1) { %>
        <a href="/dashboard?page=<%= currentPage - 1 %>">Previous</a>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <strong><%= i %></strong>
        <% } else { %>
          <a href="/dashboard?page=<%= i %>"><%= i %></a>
        <% } %>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="/dashboard?page=<%= currentPage + 1 %>">Next</a>
      <% } %>
    </nav>
  </main>
  <script>
    function toggleOnlineUsers() {
      var content = document.getElementById('online-users-content');
      content.style.display = content.style.display === 'none' ? 'block' : 'none';
    }
  </script>
</body>
  <%- include("includes/footer") %>
</html>
