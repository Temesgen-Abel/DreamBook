
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Live Video Room</title>
<style>
body { font-family: Arial; text-align:center; background:#f7f8fc; margin:0; padding:20px; }
.videos { display:flex; justify-content:center; gap:20px; flex-wrap:wrap; }
.video-wrapper { position:relative; display:inline-block; }
video { width:300px; max-width:100%; border-radius:12px; background:black; }
.username-label {
  position:absolute;
  bottom:5px;
  left:50%;
  transform:translateX(-50%);
  background:rgba(0,0,0,0.6);
  color:white;
  padding:2px 6px;
  border-radius:4px;
  font-size:14px;
}
.controls,.live-toolbar,.host-controls{
  margin:15px 0;
  display:flex;
  justify-content:center;
  gap:10px;
  flex-wrap:wrap;
}
button{
  padding:10px 14px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}
.comment-box{
  display:flex;
  max-width:900px;
  margin:auto;
  gap:10px;
}
.comment-box input{
  flex:1;
  padding:10px;
}
.reaction-feed{
  max-width:900px;
  margin:15px auto;
  background:white;
  padding:10px;
  border-radius:12px;
  min-height:120px;
  overflow-y:auto;
}
.reaction-item{
  padding:8px;
  margin-bottom:6px;
  background:#f3f4f8;
  border-radius:8px;
}
.reply-item{
  margin-left:20px;
  margin-top:4px;
  padding:6px;
  background:#e8ecf0;
  border-radius:6px;
  border-left:3px solid #007bff;
}
.reply-btn{
  font-size:12px;
  color:#007bff;
  cursor:pointer;
  margin-left:8px;
  text-decoration:underline;
}
.reply-form{
  display:none;
  margin-top:6px;
  margin-left:20px;
}
.reply-form input{
  width:calc(100% - 60px);
  padding:4px;
  border:1px solid #ccc;
  border-radius:4px;
}
.reply-form button{
  padding:4px 8px;
  margin-left:4px;
  background:#007bff;
  color:white;
  border:none;
  border-radius:4px;
  cursor:pointer;
}
#floatingReactions{
  position:fixed;
  right:20px;
  bottom:20px;
  pointer-events:none;
}
.float-reaction{
  font-size:30px;
  animation: floatUp 2s linear forwards;
}
@keyframes floatUp{
  from{opacity:1;transform:translateY(0);}
  to{opacity:0;transform:translateY(-180px);}
}
</style>
</head>
<body>

<h2>Live Video Room 🎥</h2>

<div class="videos" id="videoContainer">
  <div class="video-wrapper">
    <video id="localVideo" autoplay muted playsinline></video>
    <div class="username-label"><%= user.username %> (You)</div>
  </div>
</div>

<div class="controls">
<button onclick="toggleMute()">🎤 Mute</button>
<button onclick="toggleCamera()">📷 Camera</button>
<button onclick="toggleAudioOnly()" id="audioOnlyBtn">🔈 Audio Only</button>
<button onclick="switchCamera()">🔄 Switch</button>
<button onclick="toggleVolume()">🔊 Mute/Unmute Playback</button>
<label style="display:inline-flex; align-items:center; gap:8px;">
  Volume
  <input id="volumeSlider" type="range" min="0" max="1" step="0.05" value="1" oninput="setVolume(this.value)">
</label>
<button onclick="endLive()">⛔ End</button>
</div>

<% if(user.id === hostId){ %>
<div class="host-controls">
<button onclick="muteAll()">🔇 Mute All</button>
</div>
<% } %>

<div class="live-toolbar">
<button onclick="sendInteraction('like')">👍</button>
<button onclick="sendInteraction('heart')">❤️</button>
<button onclick="sendInteraction('laugh')">😂</button>
<button onclick="sendInteraction('crying')">😢</button>
<button onclick="shareLive()">🔗 Share link</button>
<button onclick="shareToCommunity()">📢 Share to Community</button>
</div>

<div class="live-counts">
👍 <span id="likeCount">0</span>
❤️ <span id="heartCount">0</span>
😂 <span id="laughCount">0</span>
😢 <span id="cryingCount">0</span>
🔗 <span id="shareCount">0</span>
👁️ <span id="viewerCount">1</span>
</div>

<div class="comment-box">
<input id="commentInput" placeholder="Write live comment...">
<button onclick="sendComment()">Send</button>
</div>

<div class="reaction-feed" id="reactionFeed">
<% 
// Group comments by parent_id
const topLevelComments = comments.filter(c => !c.parent_id);
const replies = comments.filter(c => c.parent_id);

topLevelComments.forEach(c => { 
%>
<div class="reaction-item" data-id="<%= c.id %>">
<strong><%= c.username %>:</strong> <%= c.comment %>
<button class="reply-btn" onclick="showReplyForm(<%= c.id %>)">Reply</button>
<div class="reply-form" id="reply-form-<%= c.id %>">
<input id="reply-input-<%= c.id %>" placeholder="Write a reply...">
<button onclick="sendReply(<%= c.id %>)">Send</button>
</div>
<% 
const commentReplies = replies.filter(r => r.parent_id === c.id);
commentReplies.forEach(reply => { 
%>
<div class="reply-item">
<strong><%= reply.username %>:</strong> <%= reply.comment %>
</div>
<% }); %>
</div>
<% }); %>
</div>

<div id="floatingReactions"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
const roomId = "<%= roomId %>";
const userId = <%= user.id %>;
const hostId = <%= hostId %>;
const username = "<%= user.username %>";

const socket = io({
  transports:["websocket","polling"]
});

let localStream;
let pcs = {};
let currentFacing = "user";
let currentVolume = 1;
let isAudioOnly = false;

function toggleAudioOnly(){
  isAudioOnly = !isAudioOnly;

  if(localStream){
    const videoTrack = localStream.getVideoTracks()[0];
    if(videoTrack){
      videoTrack.enabled = !isAudioOnly;
    }
  }

  const localVideo = document.getElementById("localVideo");
  if(isAudioOnly){
    localVideo.style.opacity = 0.4;
    localVideo.style.filter = "grayscale(100%)";
    document.getElementById("audioOnlyBtn").innerText = "🎥 Video + Audio";
  } else {
    localVideo.style.opacity = 1;
    localVideo.style.filter = "none";
    document.getElementById("audioOnlyBtn").innerText = "🔈 Audio Only";
  }
}

function setVolume(volume){
  currentVolume = Number(volume);
  document.querySelectorAll('.videos video').forEach(video=>{
    video.volume = currentVolume;
    video.muted = currentVolume === 0;
  });
}

async function startMedia(){
  localStream = await navigator.mediaDevices.getUserMedia({
    video:{ facingMode: currentFacing },
    audio:true
  });

  if(isAudioOnly){
    const videoTrack = localStream.getVideoTracks()[0];
    if(videoTrack){
      videoTrack.enabled = false;
    }
  }

  const localVideo = document.getElementById("localVideo");
  localVideo.srcObject = localStream;
  localVideo.muted = true;
}


async function joinRoom(){
  await startMedia();

  socket.emit("join_room",{
    roomId,
    userId,
    username
  });
}

function createPeerConnection(socketId, remoteName="Participant"){
  const pc = new RTCPeerConnection({
    iceServers:[
      { urls:"stun:stun.l.google.com:19302" }
    ]
  });

  pc.ontrack = (event)=>{
    let wrapper = document.getElementById(`wrapper-${socketId}`);

    if(!wrapper){
      wrapper = document.createElement("div");
      wrapper.className = "video-wrapper";
      wrapper.id = `wrapper-${socketId}`;

      const video = document.createElement("video");
      video.id = `video-${socketId}`;
      video.autoplay = true;
      video.playsInline = true;
      video.muted = true; // start muted for autoplay compliance
      video.volume = currentVolume;

      const label = document.createElement("div");
      label.className = "username-label";
      label.innerText = remoteName;

      wrapper.appendChild(video);
      wrapper.appendChild(label);

      document.getElementById("videoContainer").appendChild(wrapper);
    }

    const remoteVideo = document.getElementById(`video-${socketId}`);
    remoteVideo.srcObject = event.streams[0];
    remoteVideo.volume = currentVolume;

    remoteVideo.play().catch(()=>{
      // Some browsers require user interaction to play unmuted audio. Keep tried.
    });
  };

  pc.onicecandidate = (e)=>{
    if(e.candidate){
      socket.emit("webrtc_ice_candidate",{
        to: socketId,
        from: socket.id,
        candidate:e.candidate
      });
    }
  };

  return pc;
}

socket.on("participant_joined", async ({ socketId, username:remoteName })=>{
  if(pcs[socketId]) return;

  const pc = createPeerConnection(socketId, remoteName);
  pcs[socketId] = pc;

  localStream.getTracks().forEach(track=>{
    pc.addTrack(track, localStream);
  });

  const offer = await pc.createOffer();
  await pc.setLocalDescription(offer);

  socket.emit("webrtc_offer",{
    to: socketId,
    from: socket.id,
    sdp: offer
  });
});

socket.on("webrtc_offer", async ({ from, sdp })=>{
  if(pcs[from]) return;

  const pc = createPeerConnection(from);
  pcs[from] = pc;

  localStream.getTracks().forEach(track=>{
    pc.addTrack(track, localStream);
  });

  await pc.setRemoteDescription(new RTCSessionDescription(sdp));

  const answer = await pc.createAnswer();
  await pc.setLocalDescription(answer);

  socket.emit("webrtc_answer",{
    to: from,
    from: socket.id,
    sdp: answer
  });
});

socket.on("webrtc_answer", async ({ from, sdp })=>{
  if(pcs[from]){
    await pcs[from].setRemoteDescription(new RTCSessionDescription(sdp));
  }
});

socket.on("webrtc_ice_candidate", async ({ from, candidate })=>{
  if(pcs[from]){
    await pcs[from].addIceCandidate(new RTCIceCandidate(candidate));
  }
});

socket.on("participant_left", ({ socketId })=>{
  if(pcs[socketId]){
    pcs[socketId].close();
    delete pcs[socketId];
  }

  const wrapper = document.getElementById(`wrapper-${socketId}`);
  if(wrapper) wrapper.remove();
});

socket.on("participant_update",(data)=>{
  document.getElementById("viewerCount").innerText = data.count;
});

socket.on("live_interaction_update", (payload) => {
  const { id, username, type, comment, parentId } = payload;

  if(type === "like" || type === "heart" || type === "laugh" || type === "crying" || type === "share"){
    const map = {
      like: "likeCount",
      heart: "heartCount",
      laugh: "laughCount",
      crying: "cryingCount",
      share: "shareCount"
    };
    const counter = document.getElementById(map[type]);
    if(counter) counter.innerText = Number(counter.innerText || 0) + 1;
  }

  if(type === "comment" && comment){
    const feed = document.getElementById("reactionFeed");

    if(parentId){
      // This is a reply
      const parentElement = document.querySelector(`.reaction-item[data-id="${parentId}"]`);
      if(parentElement){
        const replyDiv = document.createElement("div");
        replyDiv.className = "reply-item";
        replyDiv.innerHTML = `<strong>${username}:</strong> ${comment}`;
        parentElement.appendChild(replyDiv);
      }
    } else {
      // This is a new top-level comment
      const item = document.createElement("div");
      item.className = "reaction-item";
      item.setAttribute("data-id", id);
      item.innerHTML = `<strong>${username}:</strong> ${comment}
        <button class="reply-btn" onclick="showReplyForm(${id})">Reply</button>
        <div class="reply-form" id="reply-form-${id}">
          <input id="reply-input-${id}" placeholder="Write a reply...">
          <button onclick="sendReply(${id})">Send</button>
        </div>`;
      feed.appendChild(item);
    }

    feed.scrollTop = feed.scrollHeight;
  }
});

socket.on("force_mute", ()=>{
  localStream.getAudioTracks().forEach(track=>track.enabled=false);
});

socket.on("force_disconnect", ()=>{
  location.href="/live";
});

function muteAll(){
  Object.keys(pcs).forEach(socketId=>{
    socket.emit("mute_participant",{ socketId });
  });
}

function toggleMute(){
  if(localStream && localStream.getAudioTracks().length){
    localStream.getAudioTracks()[0].enabled = !localStream.getAudioTracks()[0].enabled;
  }
}

function toggleCamera(){
  if(localStream && localStream.getVideoTracks().length){
    localStream.getVideoTracks()[0].enabled = !localStream.getVideoTracks()[0].enabled;
  }
}

function toggleVolume(){
  const slider = document.getElementById("volumeSlider");
  if(!slider) return;

  if(slider.value > 0){
    slider.dataset.prevVolume = slider.value;
    slider.value = 0;
  } else {
    slider.value = slider.dataset.prevVolume || 1;
  }

  setVolume(slider.value);
}

async function switchCamera(){
  if(!localStream) return;

  localStream.getTracks().forEach(track=>track.stop());
  currentFacing = currentFacing==="user" ? "environment" : "user";

  await startMedia();

  Object.values(pcs).forEach(pc=>{
    const senders = pc.getSenders().filter(sender=>sender.track && sender.track.kind === 'video');
    const newVideoTrack = localStream.getVideoTracks()[0];
    if(newVideoTrack){
      if(senders.length){
        senders.forEach(sender=>sender.replaceTrack(newVideoTrack));
      } else {
        pc.addTrack(newVideoTrack, localStream);
      }
    }
  });
}

function endLive(){
  location.href="/live";
}

async function sendInteraction(type){
  await fetch("/live-interaction",{
    method:"POST",
    headers:{ "Content-Type":"application/x-www-form-urlencoded" },
    body:new URLSearchParams({ roomId,type })
  });
}

async function sendComment(){
  const text = document.getElementById("commentInput").value.trim();
  if(!text) return;

  await fetch("/live-interaction",{
    method:"POST",
    headers:{ "Content-Type":"application/x-www-form-urlencoded" },
    body:new URLSearchParams({
      roomId,
      type:"comment",
      comment:text
    })
  });

  document.getElementById("commentInput").value="";
}

function shareLive(){
  navigator.clipboard.writeText(window.location.href);
  sendInteraction("share");
}

function shareToCommunity(){
  const liveUrl = window.location.href;
  const postBody = `🎥 I'm hosting a live dream discussion! Join me here: ${liveUrl}\n\n#LiveDreamDiscussion #DreamBook`;

  console.log("Sharing to community:", { roomId, postBody, userId, hostId });

  const formData = new URLSearchParams({
    body: postBody,
    is_live_share: 'true',
    live_room_id: roomId
  });

  console.log("Form data:", formData.toString());

  fetch("/create-post", {
    method: "POST",
    headers: {
      "Content-Type": "application/x-www-form-urlencoded",
      "X-Requested-With": "XMLHttpRequest"
    },
    body: new URLSearchParams({
      body: postBody,
      is_live_share: 'true',
      live_room_id: roomId
    })
  })
  .then(response => {
    console.log("Response received:", {
      status: response.status,
      statusText: response.statusText,
      ok: response.ok,
      redirected: response.redirected,
      url: response.url
    });

    if(response.ok){
      return response.json().catch(() => {
        console.error("Response was OK but not valid JSON");
        throw new Error("Invalid JSON response");
      });
    } else {
      return response.text().then(text => {
        console.error("Error response text:", text);
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      });
    }
  })
  .then(data => {
    console.log("Success data:", data);
    if(data.success){
      alert("Live discussion shared to community!");
      sendInteraction("share");
    } else {
      alert("Failed to share to community: " + (data.errors ? data.errors.join(", ") : data.error || "Unknown error"));
    }
  })
  .catch(error => {
    console.error("Final error:", error);
    alert("Failed to share to community. Error: " + error.message);
  });
}

function showReplyForm(commentId){
  const form = document.getElementById(`reply-form-${commentId}`);
  if(form){
    form.style.display = form.style.display === 'block' ? 'none' : 'block';
  }
}

function sendReply(parentId){
  const input = document.getElementById(`reply-input-${parentId}`);
  const text = input.value.trim();
  if(!text) return;

  fetch("/live-interaction",{
    method:"POST",
    headers:{ "Content-Type":"application/x-www-form-urlencoded" },
    body:new URLSearchParams({
      roomId,
      type:"comment",
      comment:text,
      parentId: parentId.toString()
    })
  });

  input.value = "";
  document.getElementById(`reply-form-${parentId}`).style.display = 'none';
}

joinRoom();
</script>
<form action="/dashboard" method="get">
  <button type="submit" class="btn">Back to Homepage</button>
  </form>


</body>
</html>
