<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('includes/head') %>
  <link rel="stylesheet" href="/style.css">

  <style>
    .videos {
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      justify-content:center;
      margin-top:20px;
    }

    video {
      width:300px;
      border-radius:10px;
      background:black;
    }

    .video-controls {
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      justify-content:center;
      margin-top:15px;
    }

    .links,
    .document-section,
    .participants-section {
      margin-top:25px;
      padding:15px;
      border:1px solid #ddd;
      border-radius:8px;
      background:#fff;
    }

    .participants-section ul {
      list-style:none;
      padding:0;
      margin:0;
    }

    .participants-section li {
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:6px 0;
      border-bottom:1px solid #eee;
    }

    .participants-section li:last-child {
      border-bottom:none;
    }
  </style>
</head>
<body>

<%- include('includes/header') %>

<div class="container">

  <% if (!roomId && !meetingMode) { %>

    <div class="links">
      <h3>Select Counselor / User</h3>

      <form action="/video-counseling" method="POST">
        <select name="counselorId" required>
          <option value="">-- Select --</option>

            <% users.forEach(u => { %>
          <option value="<%= u.id %>"><%= u.username %></option>
        <% }) %>
        </select>

        <button type="submit" class="btn">Request Session</button>
      </form>
    </div>

    <% if (pendingRequests.length > 0) { %>
      <div class="links">
        <h3>Pending Requests</h3>
        <ul>

          <% pendingRequests.forEach(r => { %>
            <li>
              <%= r.username %>

              <form action="/video-counseling/accept/<%= r.id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-success">Accept</button>
              </form>
            </li>
          <% }) %>

        </ul>
      </div>
    <% } %>

  <% } %>


  <% if (roomId || meetingMode) { %>

    <h2>
      <%= meetingMode ? (meeting?.title || 'Live Meeting') : 'Counseling Session' %>
    </h2>


    <% if (meetingMode && !isApproved) { %>
      <div class="links" id="meetingRequestSection">

        <% if (requestStatus === 'pending') { %>
          <p>Your request is pending.</p>
          <button id="cancelRequestBtn" class="btn btn-secondary">Cancel Request</button>

        <% } else if (requestStatus === 'rejected') { %>
          <p>Your request was rejected.</p>
          <button id="requestJoinBtn" class="btn btn-primary">Request Again</button>

        <% } else { %>
          <p>Request permission to join meeting.</p>
          <button id="requestJoinBtn" class="btn btn-primary">Request Join</button>
        <% } %>

      </div>
    <% } %>


    <% if (meetingMode && isHost) { %>
      <div class="links">
        <h3>Pending Join Requests</h3>

        <ul id="pendingRequestsList">
          <% pendingRequests.forEach(r => { %>
            <li data-user-id="<%= r.user_id %>">
              <%= r.username %>

              <button class="btn btn-success approveBtn" data-user-id="<%= r.user_id %>">Admit</button>
              <button class="btn btn-secondary rejectBtn" data-user-id="<%= r.user_id %>">Reject</button>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>


    <div id="meetingUi" style="display:<%= (!meetingMode || isApproved) ? 'block' : 'none' %>">

      <div class="videos" id="group-video-container"></div>

      <div class="video-controls">
        <button id="startCamBtn" class="btn btn-secondary">Start Camera</button>
        <button id="toggleAudioBtn" class="btn btn-primary">Mute</button>
        <button id="toggleVideoBtn" class="btn btn-primary">Stop Video</button>
        <button id="shareScreenBtn" class="btn btn-info">Share Screen</button>
        <button id="leaveBtn" class="btn btn-danger">Leave</button>

        <% if (meetingMode && isHost) { %>
          <button id="endMeetingBtn" class="btn btn-danger">End Meeting</button>
        <% } %>
      </div>


      <div class="participants-section">
        <h4>Participants</h4>
        <ul id="participantList"></ul>
      </div>


      <div class="document-section">
        <h4>Shared Documents</h4>

        <ul id="sharedDocs">

          <% [...counselingDocuments, ...groupDocuments].forEach(doc => { %>
            <li>
              <a href="/documents/<%= doc.id %>" target="_blank"><%= doc.name %></a>

              <% if (doc.editable) { %>
                <button onclick="editDocument('<%= doc.id %>')" class="btn btn-secondary btn-sm">
                  Edit
                </button>
              <% } %>
            </li>
          <% }) %>

        </ul>
      </div>

    </div>

  <% } %>

</div>

<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

let localStream;
const peers = {};

const roomId = <%= roomId ? JSON.stringify(roomId) : 'null' %>;
const meetingId = <%= meetingMode && meeting ? JSON.stringify(meeting.id) : 'null' %>;
const currentRoom = meetingId || roomId;
const userId = <%= JSON.stringify(userId) %>;

const config = {
  iceServers: [
    { urls: "stun:stun.l.google.com:19302" }
  ]
};

async function startLocalStream() {
  localStream = await navigator.mediaDevices.getUserMedia({
    video:true,
    audio:true
  });

  const video = document.createElement("video");
  video.srcObject = localStream;
  video.autoplay = true;
  video.muted = true;
  video.playsInline = true;

  document.getElementById("group-video-container").appendChild(video);
}

async function createPeer(targetId, initiator=false) {
  const pc = new RTCPeerConnection(config);

  peers[targetId] = pc;

  localStream.getTracks().forEach(track => {
    pc.addTrack(track, localStream);
  });

  pc.ontrack = event => {
    let remoteVideo = document.getElementById(targetId);

    if (!remoteVideo) {
      remoteVideo = document.createElement("video");
      remoteVideo.id = targetId;
      remoteVideo.autoplay = true;
      remoteVideo.playsInline = true;
      document.getElementById("group-video-container").appendChild(remoteVideo);
    }

    remoteVideo.srcObject = event.streams[0];
  };

  pc.onicecandidate = event => {
    if (event.candidate) {
      socket.emit("ice-candidate", {
        target: targetId,
        candidate: event.candidate
      });
    }
  };

  if (initiator) {
    const offer = await pc.createOffer();
    await pc.setLocalDescription(offer);

    socket.emit("offer", {
      target: targetId,
      offer
    });
  }

  return pc;
}

socket.on("user_joined", async ({ socketId }) => {
  await createPeer(socketId, true);
});

socket.on("offer", async ({ offer, sender }) => {
  const pc = await createPeer(sender);

  await pc.setRemoteDescription(new RTCSessionDescription(offer));

  const answer = await pc.createAnswer();
  await pc.setLocalDescription(answer);

  socket.emit("answer", {
    target: sender,
    answer
  });
});

socket.on("answer", async ({ answer, sender }) => {
  await peers[sender].setRemoteDescription(
    new RTCSessionDescription(answer)
  );
});

socket.on("ice-candidate", async ({ candidate, sender }) => {
  if (peers[sender]) {
    await peers[sender].addIceCandidate(
      new RTCIceCandidate(candidate)
    );
  }
});

socket.on("user_left", socketId => {
  if (peers[socketId]) {
    peers[socketId].close();
    delete peers[socketId];
  }

  const video = document.getElementById(socketId);
  if (video) video.remove();
});

document.getElementById("startCamBtn").onclick = async () => {
  await startLocalStream();

  socket.emit(
    meetingId ? "join_meeting" : "join_room",
    {
      [meetingId ? "meetingId" : "roomId"]: currentRoom,
      userId
    }
  );
};

document.getElementById("leaveBtn").onclick = () => {
  window.location.href = "/dashboard";
};
</script>

</body>
</html>