<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('includes/head') %>
  <link rel="stylesheet" href="/style.css">

  <style>
    .videos {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
      gap: 12px;
      margin-top: 20px;
    }

    .video-box {
      position: relative;
    }

    video {
      width: 100%;
      border-radius: 10px;
      background: black;
    }

    .participant-name {
      position: absolute;
      bottom: 6px;
      left: 6px;
      background: rgba(0,0,0,.6);
      color: white;
      padding: 4px 8px;
      border-radius: 6px;
      font-size: 12px;
    }

    .video-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 20px;
    }

    .links {
      margin: 20px 0;
    }

    .share-links a {
      display: inline-block;
      margin-right: 10px;
      margin-top: 8px;
    }

    @media(max-width:768px) {
      .video-controls {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>

<%- include('includes/header') %>

<div class="container">

  <% if (!roomId && !meetingMode) { %>

    <h2>Video Counseling / Live Discussion</h2>

    <form action="/live-meetings/create" method="POST">
      <input type="text" name="title" placeholder="Meeting Title" required>
      <input type="text" name="description" placeholder="Description">

      <label>
        <input type="checkbox" name="publishToDashboard">
        Publish on Dashboard
      </label>

      <label>
        <input type="checkbox" name="sharePublic" checked>
        Allow Public Sharing
      </label>

      <button type="submit" class="btn">Create Live Meeting</button>
    </form>

    <% if (typeof meetings !== "undefined" && meetings.length > 0) { %>
      <div class="links">
        <h3>Your Meetings</h3>
        <ul>
          <% meetings.forEach(m => { %>
            <li>
              <%= m.title %> - <%= m.is_active ? 'Active' : 'Ended' %>
              <% if (m.is_active) { %>
                <a href="/video-counseling?meetingId=<%= m.id %>" class="btn btn-primary">Join</a>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <% if (sharedMeetings && sharedMeetings.length > 0) { %>
      <div class="links">
        <h3>Shared Meetings</h3>
        <ul>
          <% sharedMeetings.forEach(m => { %>
            <li>
              <%= m.title %> - <%= m.is_active ? 'Active' : 'Ended' %>
              <% if (m.is_active) { %>
                <a href="/video-counseling?meetingId=<%= m.id %>" class="btn btn-primary">Join</a>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>

  <% } %>

  <% if (roomId || meetingMode) { %>

    <h2><%= meetingMode ? (meeting && meeting.title ? meeting.title : 'Live Meeting') : 'Counseling Session' %></h2>

    <% if (meeting && meeting.meeting_link) { %>
      <div class="links">
        <input type="text" value="<%= meeting.meeting_link %>" readonly style="width:100%">

        <div class="share-links">
          <a target="_blank"
             href="https://wa.me/?text=<%= encodeURIComponent(meeting.meeting_link) %>">WhatsApp</a>

          <a target="_blank"
             href="https://t.me/share/url?url=<%= encodeURIComponent(meeting.meeting_link) %>">Telegram</a>

          <a target="_blank"
             href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(meeting.meeting_link) %>">Facebook</a>

          <a target="_blank"
             href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(meeting.meeting_link) %>">X</a>
        </div>
      </div>
    <% } %>

    <% if (meetingMode && !isApproved) { %>
      <div id="meetingRequestSection">
        <button id="requestJoinBtn" class="btn btn-primary">Request Join</button>
      </div>
    <% } %>

    <% if (meetingMode && isHost) { %>
      <div class="links">
        <h3>Pending Join Requests</h3>
        <ul id="pendingRequestsList">
          <% pendingRequests.forEach(r => { %>
            <li>
              <%= r.username %>
              <button class="btn btn-success approveBtn" data-user-id="<%= r.user_id %>">Admit</button>
              <button class="btn btn-secondary rejectBtn" data-user-id="<%= r.user_id %>">Reject</button>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div id="meetingUi" style="display:<%= (!meetingMode || isApproved) ? 'block' : 'none' %>">

      <div class="videos" id="group-video-container"></div>

      <div class="video-controls">
        <button id="startCamBtn" class="btn btn-secondary">Start Camera</button>
        <button id="toggleAudioBtn" class="btn btn-primary">Mute</button>
        <button id="toggleVideoBtn" class="btn btn-primary">Stop Video</button>
        <button id="shareScreenBtn" class="btn btn-info">Share Screen</button>
        <button id="leaveBtn" class="btn btn-danger">Leave</button>

        <% if (meetingMode && isHost) { %>
          <button id="endMeetingBtn" class="btn btn-danger">End Meeting</button>
        <% } %>
      </div>

      <div class="participants-section">
        <h4>Participants</h4>
        <ul id="participantList">
          <% usernames.forEach(username => { %>
            <li><%= username %></li>
          <% }) %>
        </ul>
      </div>

      <% if (meeting && meeting.is_active) { %>
        <div class="links">
          <h3>Send Emotional Reaction</h3>
          <form id="reactionForm">
            <select name="reaction" required>
              <option value="">-- Select Reaction --</option>
              <option value="like">Like</option>
              <option value="love">Love</option>
              <option value="laugh">Laugh</option>
              <option value="sad">Sad</option>
              <option value="angry">Angry</option>
            </select>
            <button type="submit" class="btn btn-info">Send Reaction</button>
          </form>
        </div>
      <% } %>

    </div>

  <% } %>

</div>

<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

let localStream = null;
let screenStream = null;
const peers = {};

const roomId = <%= roomId ? JSON.stringify(roomId) : 'null' %>;
const meetingId = <%= meetingMode && meeting ? JSON.stringify(meeting.id) : 'null' %>;
const userId = <%= JSON.stringify(userId) %>;

const configuration = {
  iceServers: [
    { urls: "stun:stun.l.google.com:19302" },
    {
      urls: "turn:openrelay.metered.ca:80",
      username: "openrelayproject",
      credential: "openrelayproject"
    }
  ]
};

function createVideoElement(id, label, muted=false) {
  const container = document.getElementById("group-video-container");
  if (!container) return null;

  if (document.getElementById(id)) return document.getElementById(id);

  const wrapper = document.createElement("div");
  wrapper.id = `wrapper_${id}`;
  wrapper.className = "video-box";

  const video = document.createElement("video");
  video.id = id;
  video.autoplay = true;
  video.playsInline = true;
  video.muted = muted;

  const name = document.createElement("div");
  name.className = "participant-name";
  name.innerText = label;

  wrapper.appendChild(video);
  wrapper.appendChild(name);
  container.appendChild(wrapper);

  return video;
}

async function startLocalStream() {
  try {
    if (localStream) return;

    localStream = await navigator.mediaDevices.getUserMedia({
      video: true,
      audio: true
    });

    const video = createVideoElement("localVideo", "You", true);
    if (video) video.srcObject = localStream;

  } catch (err) {
    console.error(err);
    alert("Camera access denied");
  }
}

document.getElementById("startCamBtn")?.addEventListener("click", async () => {
  await startLocalStream();

  if (meetingId) {
    socket.emit("join_meeting", { meetingId, userId });
  }
});

document.getElementById("toggleAudioBtn")?.addEventListener("click", () => {
  localStream?.getAudioTracks().forEach(track => track.enabled = !track.enabled);
});

document.getElementById("toggleVideoBtn")?.addEventListener("click", () => {
  localStream?.getVideoTracks().forEach(track => track.enabled = !track.enabled);
});

document.getElementById("shareScreenBtn")?.addEventListener("click", async () => {
  screenStream = await navigator.mediaDevices.getDisplayMedia({ video: true });
});

document.getElementById("requestJoinBtn")?.addEventListener("click", () => {
  socket.emit("request_join_meeting", { meetingId, userId });
});

document.querySelectorAll(".approveBtn").forEach(btn => {
  btn.addEventListener("click", () => {
    socket.emit("approve_user", {
      meetingId,
      userId: btn.dataset.userId
    });
  });
});

document.querySelectorAll(".rejectBtn").forEach(btn => {
  btn.addEventListener("click", () => {
    socket.emit("reject_user", {
      meetingId,
      userId: btn.dataset.userId
    });
  });
});

document.getElementById("reactionForm")?.addEventListener("submit", function(e) {
  e.preventDefault();
  const reaction = this.reaction.value;
  socket.emit("send_reaction", { meetingId, reaction });
  alert("Reaction sent: " + reaction);
});

document.getElementById("endMeetingBtn")?.addEventListener("click", () => {
  socket.emit("end_meeting", { meetingId });
});

document.getElementById("leaveBtn")?.addEventListener("click", () => {
  location.href = "/video-counseling";
});

socket.on("approved", () => location.reload());
socket.on("meeting_ended", () => location.href = "/video-counseling");
</script>

</body>
</html>