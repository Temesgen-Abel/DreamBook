<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('includes/head') %>
  <link rel="stylesheet" href="/style.css">
  <style>
    .videos { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-top:20px; }
    video { width:300px; border-radius:10px; background:black; }
    .video-controls { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-top:15px; }
    .links { margin-top:20px; }
    .document-section { margin-top:25px; padding:15px; border:1px solid #ddd; border-radius:8px; background:#fff; }
    .participants-section { margin-top:25px; padding:15px; border:1px solid #ddd; border-radius:8px; background:#fff; }
    .participants-section ul { list-style:none; padding:0; margin:0; }
    .participants-section li { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid #eee; }
    .participants-section li:last-child { border-bottom:none; }
  </style>
</head>
<body>
<%- include('includes/header') %>

<div class="container">

  <% if (!roomId && !meetingMode) { %>
    <div class="links">
      <h3>Available Counselors:</h3>
      <ul>
        <% users.forEach(c => { %>
          <li>
            <a href="/video-counseling/<%= c.roomId || '' %>?counselorId=<%= c.id %>">Start session with <%= c.username %></a>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (pendingRequests.length && !meetingMode) { %>
    <div class="links">
      <h3>Pending Requests:</h3>
      <ul>
        <% pendingRequests.forEach(r => { %>
          <li>
            <a href="/video-counseling/<%= r.room_id %>">Accept session request from <%= r.username %></a>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (roomId || meetingMode) { %>
    <h2><%= meetingMode ? (meeting.title || 'Live Meeting') : 'Counseling Session' %></h2>

    <% if (meetingMode && !isApproved) { %>
      <div class="links" id="meetingRequestSection">
        <% if (requestStatus === 'pending') { %>
          <p>Your request to join this meeting is pending. The host will admit you when ready.</p>
          <button id="cancelRequestBtn" class="btn btn-secondary">Cancel Request</button>
        <% } else if (requestStatus === 'rejected') { %>
          <p>Your request was rejected. You can try again.</p>
          <button id="requestJoinBtn" class="btn btn-primary">Request Again</button>
        <% } else if (requestStatus === 'cancelled') { %>
          <p>Your previous request was cancelled.</p>
          <button id="requestJoinBtn" class="btn btn-primary">Request to Join</button>
        <% } else { %>
          <p>To join, send a request to the host.</p>
          <button id="requestJoinBtn" class="btn btn-primary">Request to Join</button>
        <% } %>
      </div>
    <% } %>

    <% if (meetingMode && isHost) { %>
      <div class="links" id="pendingRequestsSection">
        <h3>Pending Join Requests:</h3>
        <ul id="pendingRequestsList">
          <% pendingRequests.forEach(r => { %>
            <li data-user-id="<%= r.user_id %>">
              <%= r.username %>
              <button class="btn btn-sm btn-success approveBtn" data-user-id="<%= r.user_id %>">Admit</button>
              <button class="btn btn-sm btn-secondary rejectBtn" data-user-id="<%= r.user_id %>">Reject</button>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <div id="meetingUi" style="display: <%= (!meetingMode || isApproved) ? 'block' : 'none' %>;">
      <div class="videos" id="group-video-container"></div>
      <div class="video-controls">
        <button id="startCamBtn" class="btn btn-secondary">Start Camera</button>
        <button id="toggleAudioBtn" class="btn btn-primary">Mute</button>
        <button id="toggleVideoBtn" class="btn btn-primary">Stop Video</button>
        <button id="shareScreenBtn" class="btn btn-info">Share Screen</button>
        <button id="leaveBtn" class="btn btn-danger">Leave</button>
        <% if (meetingMode && isHost) { %>
          <button id="endMeetingBtn" class="btn btn-danger">End Meeting</button>
        <% } %>
      </div>

      <div class="participants-section">
        <h4>Participants</h4>
        <ul id="participantList"></ul>
      </div>

      <div class="document-section">
        <h4>Shared Documents</h4>
        <ul id="sharedDocs">
          <% (counselingDocuments.concat(groupDocuments)).forEach(doc => { %>
            <li>
              <a href="/documents/<%= doc.id %>" target="_blank"><%= doc.name %></a>
              <% if(doc.editable) { %>
                <button class="btn btn-sm btn-secondary" onclick="editDocument('<%= doc.id %>')">Edit</button>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  <% } %>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
let localStream = null;
let audioEnabled = true;
let videoEnabled = true;

const meetingMode = <%= JSON.stringify(meetingMode) %>;
const meetingId = <%= meetingMode ? JSON.stringify(meeting.id) : 'null' %>;
const isHost = <%= JSON.stringify(isHost) %>;
let isApproved = <%= JSON.stringify(isApproved) %>;
let requestStatus = <%= JSON.stringify(requestStatus) %>;
const userId = <%= JSON.stringify(userId) %>;

async function startLocalStream(){
  if(localStream) return localStream;
  localStream = await navigator.mediaDevices.getUserMedia({video:true,audio:true});
  const localVideo = document.createElement('video');
  localVideo.autoplay = true; localVideo.muted = true; localVideo.playsInline = true;
  localVideo.srcObject = localStream;
  document.getElementById('group-video-container').appendChild(localVideo);
  document.getElementById("startCamBtn").style.display="none";
  return localStream;
}

document.getElementById("startCamBtn")?.addEventListener("click",startLocalStream);
document.getElementById("toggleAudioBtn")?.addEventListener("click",()=>{ audioEnabled=!audioEnabled; localStream.getAudioTracks().forEach(t=>t.enabled=audioEnabled); });
document.getElementById("toggleVideoBtn")?.addEventListener("click",()=>{ videoEnabled=!videoEnabled; localStream.getVideoTracks().forEach(t=>t.enabled=videoEnabled); });
document.getElementById("leaveBtn")?.addEventListener("click",()=>{ socket.disconnect(); window.location.href="/dashboard"; });

function showMessage(text) {
  const section = document.getElementById('meetingRequestSection');
  if (!section) return;
  section.innerHTML = `<p>${text}</p>`;
}

function renderRequestSection(status) {
  requestStatus = status;
  const section = document.getElementById('meetingRequestSection');
  if (!section) return;

  if (status === 'pending') {
    section.innerHTML = `
      <p>Your request to join this meeting is pending. The host will admit you when ready.</p>
      <button id="cancelRequestBtn" class="btn btn-secondary">Cancel Request</button>
    `;
  } else if (status === 'rejected') {
    section.innerHTML = `
      <p>Your request was rejected. You can try again.</p>
      <button id="requestJoinBtn" class="btn btn-primary">Request Again</button>
    `;
  } else if (status === 'cancelled') {
    section.innerHTML = `
      <p>Your previous request was cancelled.</p>
      <button id="requestJoinBtn" class="btn btn-primary">Request to Join</button>
    `;
  } else {
    section.innerHTML = `
      <p>To join, send a request to the host.</p>
      <button id="requestJoinBtn" class="btn btn-primary">Request to Join</button>
    `;
  }

  attachRequestListeners();
}

function attachRequestListeners() {
  const requestBtn = document.getElementById('requestJoinBtn');
  const cancelBtn = document.getElementById('cancelRequestBtn');

  if (requestBtn) {
    requestBtn.onclick = () => {
      socket.emit('request_join_meeting', { meetingId, userId });
      renderRequestSection('pending');
    };
  }

  if (cancelBtn) {
    cancelBtn.onclick = () => {
      socket.emit('cancel_request', { meetingId, userId });
      renderRequestSection('cancelled');
    };
  }
}

function addPendingRequest({ socketId, userId, username }) {
  const list = document.getElementById('pendingRequestsList');
  if (!list) return;
  if (list.querySelector(`[data-user-id="${userId}"]`)) return;

  const li = document.createElement('li');
  li.dataset.userId = userId;
  const displayName = username || `User ${userId}`;
  li.innerHTML = `${displayName} ` +
    `<button class="btn btn-sm btn-success approveBtn" data-user-id="${userId}">Admit</button> ` +
    `<button class="btn btn-sm btn-secondary rejectBtn" data-user-id="${userId}">Reject</button>`;
  list.appendChild(li);
}

function removePendingRequest(userId) {
  const list = document.getElementById('pendingRequestsList');
  if (!list) return;
  const item = list.querySelector(`[data-user-id="${userId}"]`);
  if (item) item.remove();
}

function renderParticipantList(participants) {
  const list = document.getElementById('participantList');
  if (!list) return;
  list.innerHTML = '';

  participants.forEach((p) => {
    const li = document.createElement('li');
    const me = p.userId === userId;
    const roleLabel = p.role === 'host' ? ' (Host)' : '';
    const displayName = p.username || `User ${p.userId}`;

    const nameSpan = document.createElement('span');
    nameSpan.textContent = `${displayName}${me ? ' (You)' : ''}${roleLabel}`;
    li.appendChild(nameSpan);

    if (isHost && !me) {
      const kickBtn = document.createElement('button');
      kickBtn.className = 'btn btn-sm btn-danger';
      kickBtn.textContent = 'Kick';
      kickBtn.onclick = () => {
        socket.emit('kick_user', { socketId: p.socketId });
      };
      li.appendChild(kickBtn);
    }

    list.appendChild(li);
  });
}

if (meetingMode) {
  socket.emit('join_user_room', userId);

  socket.on('meeting_participants', (participants) => {
    renderParticipantList(participants);
  });

  socket.on('kicked', () => {
    alert('You have been removed from the meeting.');
    window.location.href = '/live-meetings';
  });

  if (isHost) {
    socket.emit('join_meeting', { meetingId, userId });

    socket.on('waiting_user', ({ socketId, userId, username }) => {
      addPendingRequest({ socketId, userId, username });
    });

    socket.on('request_cancelled', ({ userId }) => {
      removePendingRequest(userId);
    });

    document.getElementById('pendingRequestsList')?.addEventListener('click', (event) => {
      const target = event.target;
      if (target.matches('.approveBtn')) {
        const uid = target.dataset.userId;
        socket.emit('approve_user', { meetingId, userId: Number(uid) });
        removePendingRequest(uid);
      }
      if (target.matches('.rejectBtn')) {
        const uid = target.dataset.userId;
        socket.emit('reject_user', { meetingId, userId: Number(uid) });
        removePendingRequest(uid);
      }
    });

    socket.on('meeting_ended', () => {
      alert('Meeting ended by the host.');
      window.location.href = '/live-meetings';
    });

    document.getElementById('endMeetingBtn')?.addEventListener('click', () => {
      socket.emit('end_meeting', { meetingId });
    });

  } else {
    renderRequestSection(requestStatus);

    socket.on('approved', () => {
      isApproved = true;
      document.getElementById('meetingRequestSection')?.remove();
      document.getElementById('meetingUi')?.style.setProperty('display', 'block');
      startLocalStream().catch(() => {});
    });

    socket.on('rejected', () => {
      renderRequestSection('rejected');
    });

    socket.on('meeting_ended', () => {
      alert('Meeting ended by the host.');
      window.location.href = '/live-meetings';
    });
  }
}
</script>
</body>
</html>