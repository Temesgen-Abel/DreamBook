<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include("includes/head") %>
  <link rel="stylesheet" href="/style.css">
  <style>
    .dashboard-section { margin-bottom: 30px; padding: 20px; background: #f8f9fa; border-radius: 10px; }
    .videos { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 20px; }
    video { width: 300px; border-radius: 10px; background: black; }
    .video-controls { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-top: 15px; }
    .participant-list { margin-top: 20px; }
  </style>
</head>

<body>
<%- include("includes/header") %>

<div class="container">

  <% if (!meetingMode) { %>
    <section class="dashboard-section">
      <h2>🎥 Counseling Session</h2>

      <% if (userId && users.length) { %>
        <% if (pendingRequests.length && users[0].id !== userId) { %>
          <h3>Pending Requests</h3>
          <ul>
            <% pendingRequests.forEach(r => { %>
              <li>
                <%= r.username %>
                <form method="POST" action="/video-counseling/accept/<%= r.id %>" style="display:inline">
                  <button type="submit">Accept</button>
                </form>
              </li>
            <% }) %>
          </ul>
        <% } %>

        <h3>Request Counseling</h3>
        <form method="POST" action="/video-counseling">
          <select name="counselorId" required>
            <% users.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.username %></option>
            <% }) %>
          </select>
          <button type="submit">Request Session</button>
        </form>
      <% } else { %>
        <p>No users available.</p>
      <% } %>

    </section>
  <% } %>

  <% if (meetingMode || roomId) { %>
    <section class="dashboard-section">
      <h2>
        🎥
        <% if (meetingMode && meeting) { %>
          <%= meeting.title || "Live Meeting" %>
        <% } else { %>
          Counseling Room
        <% } %>
      </h2>

      <% if (meetingMode && isHost) { %>
        <button id="endMeetingBtn" class="btn btn-danger">End Meeting</button>
        <p class="text-muted">Host approval required for participants.</p>
      <% } %>

      <div class="videos" id="group-video-container"></div>

      <div class="video-controls">
        <button id="startCamBtn" class="btn btn-secondary">Start Camera</button>
        <button id="toggleAudioBtn" class="btn btn-primary">Mute</button>
        <button id="toggleVideoBtn" class="btn btn-primary">Stop Video</button>
        <button id="shareScreenBtn" class="btn btn-info">Share Screen</button>
        <button id="recordBtn" class="btn btn-warning">Start Recording</button>
        <button id="leaveBtn" class="btn btn-danger">Leave</button>
      </div>

      <% if (meetingMode) { %>
        <div class="participant-list">
          <h4>Participants Waiting</h4>
          <ul id="waitingUsers"></ul>
          <p id="noWaiting">No waiting participants.</p>
        </div>

        <div class="participant-list">
          <h4>Active Participants</h4>
          <ul id="activeUsers"></ul>
          <p id="noActive">No active participants.</p>
        </div>
      <% } %>

    </section>
  <% } %>

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/video-counseling-client.js"></script>

</body>
</html>