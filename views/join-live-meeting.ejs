<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('includes/head') %>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include('includes/header') %>

<div class="container" style="margin-top:40px;">
  <h1>Create Live Meeting</h1>

  <% if (preLink) { %>
    <div class="alert alert-info">
      <strong>Pre-generated Meeting Link:</strong>
      <a href="<%= preLink %>" target="_blank"><%= preLink %></a>
      <button class="btn btn-sm btn-outline-secondary ml-2" onclick="copyLink()">Copy</button>
    </div>
  <% } %>

  <form action="/live-meetings/create" method="POST" class="mt-3">
    <input type="hidden" name="preId" value="<%= preId %>">

    <div class="form-group">
      <label for="title">Meeting Title</label>
      <input type="text" class="form-control" id="title" name="title" required placeholder="Enter meeting title">
    </div>

    <div class="form-group mt-2">
      <label for="description">Description</label>
      <textarea class="form-control" id="description" name="description" rows="3" placeholder="Optional meeting description"></textarea>
    </div>

    <div class="form-group mt-2">
      <label for="scheduled_at">Scheduled Date & Time</label>
      <input type="datetime-local" class="form-control" id="scheduled_at" name="scheduled_at">
      <small class="form-text text-muted">Leave empty for immediate meeting.</small>
    </div>

    <div class="form-group mt-2">
      <label for="duration">Duration (minutes)</label>
      <input type="number" class="form-control" id="duration" name="duration" min="10" max="480" value="60">
    </div>

    <button type="submit" class="btn btn-primary mt-3">Create Meeting</button>
  </form>

</div>

<script>
function copyLink() {
  const link = "<%= preLink %>";
  if (!link) return;
  navigator.clipboard.writeText(link);
  alert("Meeting link copied to clipboard!");
}
</script>

</body>
</html>