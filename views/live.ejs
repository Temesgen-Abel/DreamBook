<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
  <meta charset="UTF-8">
  <title>Live Meetings</title>
  <link rel="stylesheet" href="/style.css">

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#f7f8fc;
      margin:0;
      padding:20px;
    }

    .container{
      max-width:1000px;
      margin:auto;
    }

    .card{
      background:white;
      padding:20px;
      margin-bottom:20px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.08);
    }

    h2{
      margin-bottom:15px;
      color:#333;
    }

    button{
      padding:10px;
      border-radius:8px;
      border:none;
      margin-top:10px;
      width:100%;
      background:#007bff;
      color:white;
      cursor:pointer;
    }

    button:hover{
      background:#0056b3;
    }

    .meeting{
      padding:15px;
      border-bottom:1px solid #eee;
    }

    .meeting:last-child{
      border-bottom:none;
    }

    .join-btn{
      display:inline-block;
      margin-top:8px;
      padding:8px 14px;
      background:#28a745;
      color:white;
      border-radius:6px;
      text-decoration:none;
    }

    .join-btn:hover{
      background:#1f7f34;
    }

    .counter{
      font-size:14px;
      color:#666;
      margin-top:6px;
    }

    .share-box{
      margin-top:10px;
    }

    .end-btn{
      background:red;
      margin-top:10px;
    }

    .end-btn:hover{
      background:darkred;
    }

  </style>
</head>
<body>

<div class="container">

  <!-- START LIVE -->
  <div class="card">
    <h2>Start Live Discussion 🎥</h2>

    <form method="POST" action="/live">

      <div class="share-box">
        <label>
          <input type="checkbox" name="shareOnDashboard" value="true" checked>
          Share on dashboard
        </label>
      </div>

      <button type="submit">Start Live Now</button>

    </form>
  </div>


  <!-- ACTIVE LIVE DISCUSSIONS -->
  <div class="card">
    <h2>Available Live Discussions 🔴</h2>

    <% if (meetings && meetings.length > 0) { %>

      <% meetings.forEach(meeting => { %>

        <div class="meeting">

          <strong><%= meeting.host_name %></strong> is live now 🔴

          <div class="counter">
            Room: <%= meeting.room_id %>
          </div>

          <div class="counter">
            Participants:
            <span id="count-<%= meeting.room_id %>">1</span>
          </div>

          <a class="join-btn" href="/video-room/<%= meeting.room_id %>">
            Join Discussion
          </a>

          <% if (meeting.host_id === userId) { %>
            <form method="POST" action="/end-meeting/<%= meeting.id %>">
              <button class="end-btn">
                End Live
              </button>
            </form>
          <% } %>

        </div>

      <% }) %>

    <% } else { %>

      <p>No live discussions available now.</p>

    <% } %>

  </div>

</div>

  <h2>Video Room</h2>

  <div class="video-container">
    <video id="localVideo" autoplay playsinline muted></video>
  </div>

<!--browser camera startup-->
<script>
  // Request camera access on page load
  window.onload = function() {
    navigator.mediaDevices.getUserMedia({ video: true, audio: true })
      .then(function(stream) {
        // We don't need to do anything with the stream here
        // Just requesting access to trigger browser permissions
        stream.getTracks().forEach(track => track.stop());
      })
      .catch(function(err) {
        console.log("Camera access denied or not available:", err);
      });
  };
</script>

<!-- SOCKET.IO -->
<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

socket.on("meeting_started", () => {
  location.reload();
});

socket.on("meeting_ended", () => {
  location.reload();
});

socket.on("participant_update", (data) => {
  const counter = document.getElementById(`count-${data.roomId}`);
  if(counter){
    counter.innerText = data.count;
  }
});
</script>

</body>
</html>