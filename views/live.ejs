<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
  <meta charset="UTF-8">
  <title>Live Meetings</title>
  <link rel="stylesheet" href="/style.css">

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#f7f8fc;
      margin:0;
      padding:20px;
    }

    .container{
      max-width:1000px;
      margin:auto;
    }

    .card{
      background:white;
      padding:20px;
      margin-bottom:20px;
      border-radius:12px;
      box-shadow:0 4px 10px rgba(0,0,0,0.08);
    }

    h2{
      margin-bottom:15px;
      color:#333;
    }

    select, button{
      padding:10px;
      border-radius:8px;
      border:1px solid #ccc;
      margin-top:10px;
      width:100%;
    }

    button{
      background:#007bff;
      color:white;
      border:none;
      cursor:pointer;
    }

    button:hover{
      background:#0056b3;
    }

    .meeting{
      padding:15px;
      border-bottom:1px solid #eee;
    }

    .meeting:last-child{
      border-bottom:none;
    }

    .join-btn{
      display:inline-block;
      margin-top:8px;
      padding:8px 14px;
      background:#28a745;
      color:white;
      border-radius:6px;
      text-decoration:none;
    }

    .join-btn:hover{
      background:#1f7f34;
    }

    .pending-box{
      background:#fff3cd;
      padding:12px;
      border-radius:8px;
      margin-bottom:10px;
    }

    .dashboard-share{
      margin-top:10px;
    }

    .counter{
      font-size:14px;
      color:#666;
    }

  </style>
</head>
<body>

<div class="container">

  <!-- CREATE LIVE MEETING -->
  <div class="card">
    <h2>Create Live Meeting 🎥</h2>

    <form method="POST" action="/live">

      <label>Select participant / counselor:</label>
      <select name="counselorId" required>
        <% users.forEach(user => { %>
          <option value="<%= user.id %>">
            <%= user.username %>
          </option>
        <% }) %>
      </select>

      <div class="dashboard-share">
        <label>
          <input type="checkbox" name="shareOnDashboard" value="true">
          Share this live discussion on dashboard
        </label>
      </div>

      <button type="submit">Create Meeting</button>

    </form>
  </div>


  <!-- PENDING REQUESTS -->
  <% if (pendingRequests && pendingRequests.length > 0) { %>
    <div class="card">
      <h2>Pending Requests ⏳</h2>

      <% pendingRequests.forEach(req => { %>
        <div class="pending-box">
          <strong><%= req.username %></strong> requested meeting

          <form method="POST" action="/approve-meeting/<%= req.id %>">
            <button type="submit">Approve</button>
          </form>
        </div>
      <% }) %>

    </div>
  <% } %>


  <!-- AVAILABLE LIVE MEETINGS -->
  <div class="card">
    <h2>Available Live Discussions 🔴</h2>

    <% if (meetings && meetings.length > 0) { %>

      <% meetings.forEach(meeting => { %>
        <div class="meeting">

          <strong>Host:</strong> <%= meeting.host_name %><br>
          <strong>Counselor:</strong> <%= meeting.counselor_name %><br>
          <strong>Room:</strong> <%= meeting.room_id %><br>

          <div class="counter">
            Participants: <span id="count-<%= meeting.room_id %>">1</span>
          </div>

          <a class="join-btn" href="/video-room/<%= meeting.room_id %>">
            Join Live Discussion
          </a>

          <% if (meeting.host_id === userId) { %>
            <form method="POST" action="/end-meeting/<%= meeting.id %>">
              <button type="submit" style="margin-top:10px;background:red;">
                End Meeting
              </button>
            </form>
          <% } %>

        </div>
      <% }) %>

    <% } else { %>

      <p>No live discussions available now.</p>

    <% } %>

  </div>

</div>


<!-- SOCKET.IO -->
<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

socket.on("meeting_started", (data) => {
  location.reload();
});

socket.on("meeting_ended", (data) => {
  location.reload();
});

socket.on("participant_update", (data) => {
  const counter = document.getElementById(`count-${data.roomId}`);
  if(counter){
    counter.innerText = data.count;
  }
});
</script>

</body>
</html>